@page "/photo/{Id:guid}"
@using SharingPictureOnline.Models
@using SharingPictureOnline.Services
@inject IPhotoService PhotoService
@inject ISocialService SocialService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject NotificationStateService NotificationState
@inject IServiceProvider ServiceProvider
@implements IDisposable

<PageTitle>Chi Tiết Ảnh | FakePinterest</PageTitle>

@if (photo == null)
{
    <div class="flex justify-center items-center h-96">
        <i class="fa-solid fa-spinner fa-spin text-4xl text-fuchsia-600"></i>
    </div>
}
else
{
    <div class="max-w-6xl mx-auto p-4 md:py-8">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row">
            <!-- Left Side: Image -->
            <div class="w-full md:w-1/2 bg-slate-100 flex items-center justify-center p-4">
                <img src="@photo.StorageKey" alt="@photo.Title" class="max-w-full max-h-[80vh] object-contain rounded-2xl shadow-sm" />
            </div>

            <!-- Right Side: Details & Comments -->
            <div class="w-full md:w-1/2 flex flex-col max-h-[80vh]">
                <!-- Header -->
                <div class="p-6 border-b border-slate-100 shrink-0">
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-3 cursor-pointer group" @onclick="GoToProfile">
                            <div class="w-12 h-12 bg-fuchsia-100 text-fuchsia-600 rounded-full flex items-center justify-center font-bold text-xl uppercase overflow-hidden border-2 border-slate-200 group-hover:border-fuchsia-300 transition">
                                @if (!string.IsNullOrEmpty(photo.User?.UserProfile?.AvatarUrl))
                                {
                                    <img src="@photo.User.UserProfile.AvatarUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    @(photo.User?.Username?.FirstOrDefault() ?? 'U')
                                }
                            </div>
                            <div>
                                <h2 class="font-bold text-slate-900 text-lg group-hover:text-fuchsia-600 transition">@(photo.User?.Username ?? "Anonymous")</h2>
                                <p class="text-sm text-slate-500">@photo.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <button @onclick="ToggleLike" class="flex items-center gap-2 group transition-colors @(isLiked ? "text-red-500" : "text-slate-500 hover:text-red-500")">
                                <i class="@(isLiked ? "fa-solid" : "fa-regular") fa-heart text-3xl group-hover:scale-110 transition-transform"></i>
                                <span class="font-bold text-xl">@photo.LikeCount</span>
                            </button>
                        </div>
                    </div>
                    <h1 class="text-2xl font-bold text-slate-900 mb-2">@photo.Title</h1>
                    @if (!string.IsNullOrEmpty(photo.Description))
                    {
                        <p class="text-slate-600 whitespace-pre-wrap">@photo.Description</p>
                    }
                </div>

                <!-- Comments List -->
                <div class="flex-1 overflow-y-auto p-6 space-y-4 bg-slate-50">
                    <h3 class="font-bold text-slate-900 flex items-center gap-2 mb-4 text-lg">
                        <i class="fa-regular fa-comment-dots"></i> 
                        Bình luận (@photo.CommentCount)
                    </h3>

                    @if (!comments.Any())
                    {
                        <p class="text-slate-500 text-center py-8">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                    }
                    else
                    {
                        @foreach (var c in comments)
                        {
                            <div class="flex flex-col gap-2">
                                <!-- Original comment -->
                                <div class="flex gap-3">
                                    <div class="w-10 h-10 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center font-bold text-sm shrink-0 uppercase overflow-hidden">
                                        @if (!string.IsNullOrEmpty(c.User?.UserProfile?.AvatarUrl))
                                        {
                                            <img src="@c.User.UserProfile.AvatarUrl" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            @(c.User?.Username?.FirstOrDefault() ?? 'U')
                                        }
                                    </div>
                                    <div class="flex-1">
                                        <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm border border-slate-100 inline-block">
                                            <p class="font-bold text-sm text-slate-900 mb-1">@(c.User?.Username ?? "User")</p>
                                            <p class="text-slate-700 text-sm whitespace-pre-wrap">@c.Content</p>
                                        </div>
                                        <div class="flex items-center gap-4 mt-1 ml-2 text-xs text-slate-400">
                                            <span>@c.CreatedAt.ToString("g")</span>
                                            @if (currentUser != null)
                                            {
                                                <button @onclick="() => StartReply(c)" class="font-semibold text-slate-500 hover:text-fuchsia-600 transition">Phản hồi</button>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <!-- Replies -->
                                @if (c.InverseParent != null && c.InverseParent.Any())
                                {
                                    <div class="ml-10 space-y-3 mt-2">
                                        @foreach (var reply in c.InverseParent.OrderBy(r => r.CreatedAt))
                                        {
                                            <div class="flex gap-3">
                                                <div class="w-8 h-8 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center font-bold text-xs shrink-0 uppercase overflow-hidden">
                                                    @if (!string.IsNullOrEmpty(reply.User?.UserProfile?.AvatarUrl))
                                                    {
                                                        <img src="@reply.User.UserProfile.AvatarUrl" class="w-full h-full object-cover" />
                                                    }
                                                    else
                                                    {
                                                        @(reply.User?.Username?.FirstOrDefault() ?? 'U')
                                                    }
                                                </div>
                                                <div class="flex-1">
                                                    <div class="bg-white p-2.5 rounded-2xl rounded-tl-none shadow-sm border border-slate-100 inline-block">
                                                        <p class="font-bold text-sm text-slate-900 mb-1">@(reply.User?.Username ?? "User")</p>
                                                        <p class="text-slate-700 text-sm whitespace-pre-wrap">@reply.Content</p>
                                                    </div>
                                                    <div class="flex items-center gap-4 mt-1 ml-2 text-xs text-slate-400">
                                                        <span>@reply.CreatedAt.ToString("g")</span>
                                                        @if (currentUser != null)
                                                        {
                                                            <button @onclick="() => StartReplyToReply(c, reply)" class="font-semibold text-slate-500 hover:text-fuchsia-600 transition">Phản hồi</button>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                <!-- Comment Input -->
                <div class="p-4 border-t border-slate-100 shrink-0 bg-white shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] relative">
                    @if (replyingToCommentId != null)
                    {
                        <div class="absolute -top-8 left-4 bg-fuchsia-100 text-fuchsia-800 text-xs px-3 py-1.5 rounded-t-lg font-medium flex items-center gap-2 border border-b-0 border-fuchsia-200 shadow-sm z-10">
                            <span>Đang phản hồi <strong>@replyingToUsername</strong></span>
                            <button type="button" @onclick="CancelReply" class="hover:text-fuchsia-900 w-4 h-4 flex items-center justify-center rounded-full hover:bg-fuchsia-200 transition"><i class="fa-solid fa-xmark"></i></button>
                        </div>
                    }
                    @if (currentUser != null)
                    {
                        <form @onsubmit="SubmitComment" @onsubmit:preventDefault class="flex gap-3">
                            <div class="w-10 h-10 bg-fuchsia-600 text-white rounded-full flex items-center justify-center font-bold shrink-0 uppercase overflow-hidden">
                                @if (!string.IsNullOrEmpty(currentUser.UserProfile?.AvatarUrl))
                                {
                                    <img src="@currentUser.UserProfile.AvatarUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    @(currentUser.Username?.FirstOrDefault() ?? 'U')
                                }
                            </div>
                            <div class="flex-1 flex gap-2">
                                <input type="text" @bind="newCommentText" 
                                       placeholder="@(replyingToCommentId == null ? "Thêm bình luận..." : $"Viết phản hồi cho {replyingToUsername}...")" 
                                       class="w-full bg-slate-100 border-transparent rounded-full px-4 py-2 focus:bg-white focus:border-fuchsia-300 focus:ring-2 focus:ring-fuchsia-100 transition-all">
                                <button type="submit" disabled="@string.IsNullOrWhiteSpace(newCommentText)" 
                                        class="bg-fuchsia-600 text-white px-4 rounded-full font-bold hover:bg-fuchsia-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shrink-0">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="text-center p-4 bg-slate-100 rounded-xl">
                            <p class="text-slate-600 mb-2">Đăng nhập để tham gia bình luận và thả tim ảnh nhé!</p>
                            <a href="/login" class="inline-block bg-slate-900 text-white px-6 py-2 rounded-full font-bold hover:bg-slate-800 transition">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Photo? photo;
    private IEnumerable<Comment> comments = new List<Comment>();
    private User? currentUser;
    private bool isLiked = false;
    private string newCommentText = "";
    private Guid? replyingToCommentId;
    private string replyingToUsername = "";

    protected override async Task OnInitializedAsync()
    {
        photo = await PhotoService.GetPhotoByIdAsync(Id);
        if (photo == null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        comments = await SocialService.GetCommentsByPhotoIdAsync(Id);
        currentUser = await AuthService.GetCurrentUserAsync();

        if (currentUser != null)
        {
            isLiked = await SocialService.HasLikedAsync(currentUser.UserId, Id);
        }

        NotificationState.OnPhotoUpdated += HandlePhotoUpdated;
    }

    private async void HandlePhotoUpdated(Guid updatedPhotoId)
    {
        if (updatedPhotoId == Id)
        {
            await InvokeAsync(async () => {
                using var scope = ServiceProvider.CreateScope();
                var scopedPhotoService = scope.ServiceProvider.GetRequiredService<IPhotoService>();
                var scopedSocialService = scope.ServiceProvider.GetRequiredService<ISocialService>();
                
                photo = await scopedPhotoService.GetPhotoByIdAsync(Id);
                comments = await scopedSocialService.GetCommentsByPhotoIdAsync(Id);
                StateHasChanged();
            });
        }
    }

    public void Dispose()
    {
        NotificationState.OnPhotoUpdated -= HandlePhotoUpdated;
    }

    private void GoToProfile()
    {
        if (photo?.User != null && !string.IsNullOrEmpty(photo.User.Username))
        {
            Navigation.NavigateTo($"/profile/{photo.User.Username}");
        }
    }

    private async Task ToggleLike()
    {
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (isLiked)
        {
            var success = await SocialService.UnlikePhotoAsync(currentUser.UserId, Id);
            if (success) isLiked = false;
        }
        else
        {
            var success = await SocialService.LikePhotoAsync(currentUser.UserId, Id);
            if (success) isLiked = true;
        }
    }

    private void StartReply(Comment parentComment)
    {
        replyingToCommentId = parentComment.CommentId;
        replyingToUsername = parentComment.User?.Username ?? "User";
    }

    private void StartReplyToReply(Comment rootComment, Comment reply)
    {
        replyingToCommentId = rootComment.CommentId;
        replyingToUsername = reply.User?.Username ?? "User";
        newCommentText = $"@{replyingToUsername} ";
    }

    private void CancelReply()
    {
        replyingToCommentId = null;
        replyingToUsername = "";
    }

    private async Task SubmitComment()
    {
        if (currentUser == null || string.IsNullOrWhiteSpace(newCommentText) || photo == null) return;

        var comment = new Comment
        {
            CommentId = Guid.NewGuid(),
            UserId = currentUser.UserId,
            PhotoId = Id,
            Content = newCommentText,
            ParentId = replyingToCommentId
        };

        await SocialService.AddCommentAsync(comment);
        newCommentText = "";
        CancelReply();
    }
}