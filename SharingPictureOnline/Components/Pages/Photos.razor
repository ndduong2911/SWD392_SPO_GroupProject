@page "/photos"
@using SharingPictureOnline.Services
@inject IPhotoService PhotoService

<PageTitle>Photos</PageTitle>

<h3>All Photos</h3>

@if (photos == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        @foreach (var photo in photos)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <img src="@GetImageUrl(photo.StorageKey)" class="card-img-top" alt="@photo.Title" />
                    <div class="card-body">
                        <h5 class="card-title">@photo.Title</h5>
                        <p class="card-text">@photo.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private IEnumerable<Models.Photo>? photos;

    protected override async Task OnInitializedAsync()
    {
        photos = await PhotoService.GetAllPhotosAsync();
    }

    private string GetImageUrl(string storageKey)
    {
        return $"/uploads/{storageKey}";
    }
}
