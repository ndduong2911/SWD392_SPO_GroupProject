@page "/register"
@using SharingPictureOnline.Services
@using Microsoft.Extensions.Logging
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Register> Logger

<PageTitle>Đăng ký | FakePinterest</PageTitle>

<div class="min-h-screen bg-slate-50 flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-8">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-fuchsia-100 rounded-full mb-4">
                <i class="fa-solid fa-user-plus text-3xl text-fuchsia-600"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-2">Tạo tài khoản</h2>
            <p class="text-slate-500">Tham gia cộng đồng FakePinterest ngay hôm nay</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
                <i class="fa-solid fa-circle-exclamation mr-2"></i>@errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
                <i class="fa-solid fa-circle-check mr-2"></i>@successMessage
            </div>
        }

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="RegisterForm" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Tên đăng nhập <span class="text-fuchsia-600">*</span>
                </label>
                <InputText @bind-Value="registerModel.Username" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="Nhập tên đăng nhập" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Email <span class="text-fuchsia-600">*</span>
                </label>
                <InputText type="email" @bind-Value="registerModel.Email" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="username@domain.com" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Mật khẩu <span class="text-fuchsia-600">*</span>
                </label>
                <InputText type="password" @bind-Value="registerModel.Password" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="Ít nhất 8 ký tự" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Xác nhận mật khẩu <span class="text-fuchsia-600">*</span>
                </label>
                <InputText type="password" @bind-Value="registerModel.ConfirmPassword" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="Nhập lại mật khẩu" />
            </div>

            <button type="submit" 
                    disabled="@isLoading"
                    class="w-full py-3 bg-fuchsia-600 hover:bg-fuchsia-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
                @if (isLoading)
                {
                    <i class="fa-solid fa-spinner fa-spin mr-2"></i><span>Đang đăng ký...</span>
                }
                else
                {
                    <span>Đăng ký</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-6 text-sm text-slate-600">
            Đã có tài khoản? 
            <a href="/login" class="text-fuchsia-600 hover:text-fuchsia-700 font-semibold ml-1">
                Đăng nhập ngay
            </a>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Mật khẩu xác nhận không khớp!";
            isLoading = false;
            return;
        }

        try
        {
            Logger.LogInformation("Attempting registration for username: {Username}, email: {Email}", 
                registerModel.Username, registerModel.Email);
            
            var user = await AuthService.RegisterAsync(
                registerModel.Username, 
                registerModel.Email, 
                registerModel.Password);
            
            Logger.LogInformation("Registration successful for user: {Username}", user.Username);
            successMessage = "Đăng ký thành công! Đang chuyển hướng...";
            StateHasChanged();
            
            await Task.Delay(500);
            Navigation.NavigateTo("/", true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during registration for username: {Username}", registerModel.Username);
            errorMessage = $"Đã xảy ra lỗi: {ex.Message}. Tên đăng nhập hoặc email có thể đã tồn tại!";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class RegisterModel
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
