@page "/login"
@using SharingPictureOnline.Services
@using Microsoft.Extensions.Logging
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Đăng nhập | FakePinterest</PageTitle>

<div class="min-h-screen bg-slate-50 flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-8">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-fuchsia-100 rounded-full mb-4">
                <i class="fa-solid fa-camera-retro text-3xl text-fuchsia-600"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-2">Chào mừng trở lại</h2>
            <p class="text-slate-500">Đăng nhập vào tài khoản FakePinterest của bạn</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
                <i class="fa-solid fa-circle-exclamation mr-2"></i>@errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
                <i class="fa-solid fa-circle-check mr-2"></i>@successMessage
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="LoginForm" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Tên đăng nhập hoặc Email <span class="text-fuchsia-600">*</span>
                </label>
                <InputText @bind-Value="loginModel.UsernameOrEmail" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="Nhập tên đăng nhập hoặc email" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Mật khẩu <span class="text-fuchsia-600">*</span>
                </label>
                <InputText type="password" @bind-Value="loginModel.Password" 
                           class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                           placeholder="Nhập mật khẩu" />
            </div>

            <div class="flex items-center justify-between text-sm">
                <label class="flex items-center gap-2 text-slate-600 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 text-fuchsia-600 border-slate-300 rounded focus:ring-fuchsia-500">
                    <span>Ghi nhớ đăng nhập</span>
                </label>
                <a href="/forgot-password" class="text-fuchsia-600 hover:text-fuchsia-700 font-semibold">
                    Quên mật khẩu?
                </a>
            </div>

            <button type="submit" 
                    disabled="@isLoading"
                    class="w-full py-3 bg-fuchsia-600 hover:bg-fuchsia-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
                @if (isLoading)
                {
                    <i class="fa-solid fa-spinner fa-spin mr-2"></i><span>Đang đăng nhập...</span>
                }
                else
                {
                    <span>Đăng nhập</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-6 text-sm text-slate-600">
            Chưa có tài khoản? 
            <a href="/register" class="text-fuchsia-600 hover:text-fuchsia-700 font-semibold ml-1">
                Đăng ký ngay
            </a>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            Logger.LogInformation("Attempting login for user: {Username}", loginModel.UsernameOrEmail);
            
            var user = await AuthService.LoginAsync(loginModel.UsernameOrEmail, loginModel.Password);
            
            if (user != null)
            {
                Logger.LogInformation("Login successful for user: {Username}", user.Username);
                successMessage = "Đăng nhập thành công! Đang chuyển hướng...";
                StateHasChanged();
                
                await Task.Delay(500);
                Navigation.NavigateTo("/", true);
            }
            else
            {
                Logger.LogWarning("Login failed - Invalid credentials for: {Username}", loginModel.UsernameOrEmail);
                errorMessage = "Tên đăng nhập hoặc mật khẩu không đúng!";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during login for user: {Username}", loginModel.UsernameOrEmail);
            errorMessage = $"Đã xảy ra lỗi: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class LoginModel
    {
        public string UsernameOrEmail { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
