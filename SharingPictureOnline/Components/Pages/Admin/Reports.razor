@page "/admin/reports"
@rendermode InteractiveServer

@using SharingPictureOnline.Models
@using SharingPictureOnline.Services

@inject IReportService ReportService

<PageTitle>Report Management</PageTitle>

<div class="min-h-screen bg-slate-50 p-6">
    <div class="mx-auto max-w-7xl">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-slate-800">
                    Báo cáo đang chờ xử lý
                </h1>

                <p class="mt-1 text-slate-500">
                    Danh sách báo cáo đã được người dùng submit.
                </p>
            </div>

            <button type="button"
                    @onclick="LoadReportsAsync"
                    disabled="@isLoading"
                    class="rounded-lg border border-slate-300
                bg-white px-4 py-2 hover:bg-slate-100
                disabled:opacity-50">
                <i class="fa-solid fa-rotate-right mr-2"></i>
                Làm mới
            </button>
        </div>

        @if (isLoading)
        {
            <div class="rounded-xl bg-white p-10 text-center shadow-sm">
                <i class="fa-solid fa-spinner fa-spin
                    text-3xl text-fuchsia-600">
                </i>

                <p class="mt-3 text-slate-500">
                    Đang tải báo cáo...
                </p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="rounded-xl bg-red-50 p-4 text-red-700">
                @errorMessage
            </div>
        }
        else if (pendingReports.Count == 0)
        {
            <div class="rounded-xl bg-white p-12
                text-center shadow-sm">

                <i class="fa-solid fa-circle-check
                    text-5xl text-green-500">
                </i>

                <h2 class="mt-4 text-lg font-semibold text-slate-700">
                    Chưa có báo cáo nào được submit
                </h2>
            </div>
        }
        else
        {
            <div class="mb-4 rounded-xl bg-white p-4 shadow-sm">
                <span class="font-medium text-slate-700">
                    Tổng báo cáo đang chờ:
                </span>

                <span class="ml-2 rounded-full bg-amber-100
                    px-3 py-1 font-bold text-amber-700">
                    @pendingReports.Count
                </span>
            </div>

            <div class="overflow-x-auto rounded-xl bg-white shadow-sm">
                <table class="w-full text-left">
                    <thead class="border-b bg-slate-100 text-slate-600">
                        <tr>
                            <th class="px-5 py-4">Người báo cáo</th>
                            <th class="px-5 py-4">Đối tượng</th>
                            <th class="px-5 py-4">Loại vi phạm</th>
                            <th class="px-5 py-4">Lý do</th>
                            <th class="px-5 py-4">Ngày gửi</th>
                            <th class="px-5 py-4">Trạng thái</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var report in pendingReports)
                        {
                            <tr class="border-b hover:bg-slate-50">
                                <td class="px-5 py-4">
                                    <div class="font-medium text-slate-800">
                                        @(report.Reporter?.Username
                                            ?? "Unknown user")
                                    </div>
                                </td>

                                <td class="px-5 py-4">
                                    <span class="rounded-full bg-blue-100
                                        px-2 py-1 text-xs
                                        font-medium text-blue-700">
                                        @GetTargetLabel(report.TargetType)
                                    </span>

                                    <div class="mt-1 text-xs text-slate-500">
                                        @report.TargetId
                                    </div>
                                </td>

                                <td class="px-5 py-4">
                                    @GetViolationLabel(report.Reason)
                                </td>

                                <td class="max-w-sm px-5 py-4">
                                    @GetReasonDetail(report.Reason)
                                </td>

                                <td class="whitespace-nowrap px-5 py-4">
                                    @($"{report.CreatedAt:dd/MM/yyyy HH:mm}")
                                </td>

                                <td class="px-5 py-4">
                                    <span class="rounded-full bg-amber-100
                                        px-3 py-1 text-xs
                                        font-semibold text-amber-700">
                                        @report.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<Report> pendingReports =
        Array.Empty<Report>();

    private bool isLoading;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportsAsync();
    }

    private async Task LoadReportsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            pendingReports =
                await ReportService.GetPendingReportsAsync();
        }
        catch (Exception)
        {
            errorMessage =
                "Không thể tải danh sách báo cáo.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetTargetLabel(string? targetType)
    {
        return targetType switch
        {
            "PHOTO" => "Ảnh",
            "PROFILE" => "Trang cá nhân",
            _ => "Không xác định"
        };
    }

    private static string GetViolationLabel(string? storedReason)
    {
        var type = GetReasonPart(storedReason, 0);

        return type switch
        {
            "SPAM" => "Spam / giả mạo",
            "HARASSMENT" => "Quấy rối",
            "VIOLENCE" => "Bạo lực",
            "NUDITY" => "Nội dung nhạy cảm",
            "COPYRIGHT" => "Vi phạm bản quyền",
            "OTHER" => "Khác",
            _ => "Không xác định"
        };
    }

    private static string GetReasonDetail(string? storedReason)
    {
        return GetReasonPart(storedReason, 1);
    }

    private static string GetReasonPart(
        string? storedReason,
        int partIndex)
    {
        if (string.IsNullOrWhiteSpace(storedReason))
        {
            return "-";
        }

        var parts = storedReason.Split(
            '|',
            2,
            StringSplitOptions.TrimEntries);

        return partIndex < parts.Length
            ? parts[partIndex]
            : "-";
    }
}