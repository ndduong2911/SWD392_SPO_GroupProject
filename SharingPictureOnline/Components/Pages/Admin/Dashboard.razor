@page "/admin"
@rendermode InteractiveServer
@using SharingPictureOnline.Services
@using SharingPictureOnline.Models
@inject IAuthService AuthService
@inject IAdminService AdminService
@inject NavigationManager Navigation

<PageTitle>Admin Dashboard | FakePinterest</PageTitle>

<div class="min-h-screen bg-slate-50">
    @if (currentUser?.Role != "ADMIN")
    {
        <div class="flex items-center justify-center min-h-screen">
            <div class="text-center">
                <i class="fa-solid fa-ban text-4xl text-red-600 mb-4"></i>
                <p class="text-slate-700 font-semibold">Bạn không có quyền truy cập trang này</p>
            </div>
        </div>
    }
    else if (isLoading)
    {
        <div class="flex items-center justify-center min-h-screen">
            <i class="fa-solid fa-spinner fa-spin text-4xl text-fuchsia-600"></i>
        </div>
    }
    else
    {
        <div class="max-w-7xl mx-auto px-4 py-8">
            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-slate-800">Dashboard</h1>
                <p class="text-slate-500 mt-1">Tổng quan hệ thống - Chào mừng, @currentUser.Username!</p>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <!-- Total Users -->
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl shadow-lg p-6 text-white">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-blue-100 text-sm font-medium">Tổng Người Dùng</p>
                            <h3 class="text-3xl font-bold mt-1">@stats.TotalUsers</h3>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-users text-2xl"></i>
                        </div>
                    </div>
                    <button @onclick='() => Navigation.NavigateTo("/admin/accounts")' 
                            class="text-sm text-blue-100 hover:text-white flex items-center gap-1">
                        Xem chi tiết <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>

                <!-- Total Photos -->
                <div class="bg-gradient-to-br from-yellow-500 to-orange-500 rounded-xl shadow-lg p-6 text-white">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-yellow-100 text-sm font-medium">Tổng Ảnh</p>
                            <h3 class="text-3xl font-bold mt-1">@stats.TotalPhotos</h3>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-images text-2xl"></i>
                        </div>
                    </div>
                    <p class="text-sm text-yellow-100">
                        +@stats.NewPhotosThisMonth ảnh mới tháng này
                    </p>
                </div>

                <!-- Total Tags -->
                <div class="bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl shadow-lg p-6 text-white">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-green-100 text-sm font-medium">Tổng Tags</p>
                            <h3 class="text-3xl font-bold mt-1">@stats.TotalTags</h3>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-tags text-2xl"></i>
                        </div>
                    </div>
                    <button @onclick='() => Navigation.NavigateTo("/admin/tags")' 
                            class="text-sm text-green-100 hover:text-white flex items-center gap-1">
                        Quản lý tags <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>

                <!-- Pending Reports -->
                <div class="bg-gradient-to-br from-red-500 to-pink-600 rounded-xl shadow-lg p-6 text-white">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <p class="text-red-100 text-sm font-medium">Báo Cáo Chờ Xử Lý</p>
                            <h3 class="text-3xl font-bold mt-1">@stats.PendingReports</h3>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">
                            <i class="fa-solid fa-flag text-2xl"></i>
                        </div>
                    </div>
                    <button @onclick='() => Navigation.NavigateTo("/admin/reports")' 
                            class="text-sm text-red-100 hover:text-white flex items-center gap-1">
                        Xem báo cáo <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <!-- User Registration Chart -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-bold text-slate-800">
                            <i class="fa-solid fa-chart-line text-blue-600 mr-2"></i>
                            Đăng Ký Người Dùng (6 tháng)
                        </h2>
                    </div>
                    <div class="h-64 flex items-end justify-around gap-2">
                        @foreach (var month in userRegistrationData)
                        {
                            var maxValue = userRegistrationData.Values.Max();
                            var height = maxValue > 0 ? (month.Value * 100.0 / maxValue) : 0;
                            <div class="flex-1 flex flex-col items-center gap-2">
                                <div class="relative w-full bg-blue-500 rounded-t-lg hover:bg-blue-600 transition cursor-pointer group"
                                     style="height: @height%">
                                    <div class="absolute -top-6 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition whitespace-nowrap">
                                        @month.Value người dùng
                                    </div>
                                </div>
                                <span class="text-xs text-slate-600">@month.Key</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Photo Upload Chart -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-bold text-slate-800">
                            <i class="fa-solid fa-chart-bar text-green-600 mr-2"></i>
                            Upload Ảnh (6 tháng)
                        </h2>
                    </div>
                    <div class="h-64 flex items-end justify-around gap-2">
                        @foreach (var month in photoUploadData)
                        {
                            var maxValue = photoUploadData.Values.Max();
                            var height = maxValue > 0 ? (month.Value * 100.0 / maxValue) : 0;
                            <div class="flex-1 flex flex-col items-center gap-2">
                                <div class="relative w-full bg-green-500 rounded-t-lg hover:bg-green-600 transition cursor-pointer group"
                                     style="height: @height%">
                                    <div class="absolute -top-6 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition whitespace-nowrap">
                                        @month.Value ảnh
                                    </div>
                                </div>
                                <span class="text-xs text-slate-600">@month.Key</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Recent Users -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-800">
                            <i class="fa-solid fa-user-plus text-blue-600 mr-2"></i>
                            Người Dùng Mới
                        </h2>
                        <button @onclick='() => Navigation.NavigateTo("/admin/accounts")' 
                                class="text-sm text-blue-600 hover:text-blue-700">
                            Xem tất cả
                        </button>
                    </div>
                    <div class="divide-y divide-slate-200">
                        @foreach (var user in recentUsers)
                        {
                            <div class="px-6 py-3 hover:bg-slate-50">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-fuchsia-100 rounded-full flex items-center justify-center">
                                        <i class="fa-solid fa-user text-fuchsia-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <p class="font-semibold text-slate-800">@user.Username</p>
                                        <p class="text-xs text-slate-500">@user.Email</p>
                                    </div>
                                    <div class="text-right">
                                        <span class="@GetRoleBadgeClass(user.Role)">@user.Role</span>
                                        <p class="text-xs text-slate-500 mt-1">@user.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Recent Photos -->
                <div class="bg-white rounded-xl shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                        <h2 class="text-lg font-bold text-slate-800">
                            <i class="fa-solid fa-image text-green-600 mr-2"></i>
                            Ảnh Mới Upload
                        </h2>
                    </div>
                    <div class="divide-y divide-slate-200">
                        @foreach (var photo in recentPhotos)
                        {
                            <div class="px-6 py-3 hover:bg-slate-50">
                                <div class="flex items-center gap-3">
                                    <div class="w-16 h-16 bg-slate-100 rounded-lg overflow-hidden">
                                        <img src="@photo.StorageKey" alt="@photo.Title" class="w-full h-full object-cover" />
                                    </div>
                                    <div class="flex-1">
                                        <p class="font-semibold text-slate-800">@photo.Title</p>
                                        <p class="text-xs text-slate-500">
                                            <i class="fa-solid fa-user mr-1"></i>@photo.User?.Username
                                        </p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xs text-slate-500">@photo.UploadedAt.ToString("dd/MM/yyyy")</p>
                                        <div class="flex items-center gap-2 mt-1 text-xs text-slate-600">
                                            <span><i class="fa-solid fa-heart text-red-500"></i> @photo.LikeCount</span>
                                            <span><i class="fa-solid fa-comment text-blue-500"></i> @photo.CommentCount</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="mt-8 bg-gradient-to-r from-fuchsia-500 to-purple-600 rounded-xl shadow-lg p-6 text-white">
                <h2 class="text-xl font-bold mb-4">Truy Cập Nhanh</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <button @onclick='() => Navigation.NavigateTo("/admin/accounts")' 
                            class="bg-white bg-opacity-20 hover:bg-opacity-30 rounded-lg p-4 transition text-center">
                        <i class="fa-solid fa-users text-3xl mb-2"></i>
                        <p class="text-sm font-semibold">Tài Khoản</p>
                    </button>
                    <button @onclick='() => Navigation.NavigateTo("/admin/tags")' 
                            class="bg-white bg-opacity-20 hover:bg-opacity-30 rounded-lg p-4 transition text-center">
                        <i class="fa-solid fa-tags text-3xl mb-2"></i>
                        <p class="text-sm font-semibold">Tags</p>
                    </button>
                    <button @onclick='() => Navigation.NavigateTo("/admin/settings")' 
                            class="bg-white bg-opacity-20 hover:bg-opacity-30 rounded-lg p-4 transition text-center">
                        <i class="fa-solid fa-cog text-3xl mb-2"></i>
                        <p class="text-sm font-semibold">Cài Đặt</p>
                    </button>
                    <button @onclick='() => Navigation.NavigateTo("/admin/reports")' 
                            class="bg-white bg-opacity-20 hover:bg-opacity-30 rounded-lg p-4 transition text-center">
                        <i class="fa-solid fa-flag text-3xl mb-2"></i>
                        <p class="text-sm font-semibold">Báo Cáo</p>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private Models.User? currentUser;
    private DashboardStats stats = new();
    private List<User> recentUsers = new();
    private List<Photo> recentPhotos = new();
    private Dictionary<string, int> userRegistrationData = new();
    private Dictionary<string, int> photoUploadData = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        
        if (currentUser?.Role != "ADMIN")
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            stats = await AdminService.GetDashboardStatsAsync();
            recentUsers = await AdminService.GetRecentUsersAsync(5);
            recentPhotos = await AdminService.GetRecentPhotosAsync(5);
            userRegistrationData = await AdminService.GetUserRegistrationByMonthAsync();
            photoUploadData = await AdminService.GetPhotoUploadByMonthAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetRoleBadgeClass(string role)
    {
        return role switch
        {
            "ADMIN" => "px-2 py-1 bg-red-100 text-red-700 rounded text-xs font-semibold",
            "MODERATOR" => "px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs font-semibold",
            _ => "px-2 py-1 bg-slate-100 text-slate-700 rounded text-xs font-semibold"
        };
    }
}
