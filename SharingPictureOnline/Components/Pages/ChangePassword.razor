@page "/change-password"
@rendermode InteractiveServer
@using SharingPictureOnline.Services
@using Microsoft.Extensions.Logging
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<ChangePassword> Logger

<PageTitle>Đổi mật khẩu | FakePinterest</PageTitle>

<div class="min-h-screen bg-slate-50 flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-8">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-fuchsia-100 rounded-full mb-4">
                <i class="fa-solid fa-key text-3xl text-fuchsia-600"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-800 mb-2">Đổi mật khẩu</h2>
            <p class="text-slate-500">Cập nhật mật khẩu để bảo mật tài khoản</p>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
                <i class="fa-solid fa-circle-check"></i>
                <span>@successMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-2">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@errorMessage</span>
            </div>
        }

        <EditForm Model="@passwordModel" OnValidSubmit="HandleChangePassword" FormName="ChangePasswordForm" class="space-y-6">
            <!-- Current Password -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Mật khẩu hiện tại <span class="text-fuchsia-600">*</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                        <i class="fa-solid fa-lock"></i>
                    </span>
                    <InputText type="@(showCurrentPassword ? "text" : "password")" 
                               @bind-Value="passwordModel.CurrentPassword" 
                               class="w-full pl-11 pr-12 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                               placeholder="Nhập mật khẩu hiện tại" />
                    <button type="button" 
                            @onclick="() => showCurrentPassword = !showCurrentPassword"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                        <i class="fa-solid @(showCurrentPassword ? "fa-eye-slash" : "fa-eye")"></i>
                    </button>
                </div>
            </div>

            <!-- New Password -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Mật khẩu mới <span class="text-fuchsia-600">*</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                        <i class="fa-solid fa-key"></i>
                    </span>
                    <InputText type="@(showNewPassword ? "text" : "password")" 
                               @bind-Value="passwordModel.NewPassword" 
                               class="w-full pl-11 pr-12 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                               placeholder="Ít nhất 8 ký tự" />
                    <button type="button" 
                            @onclick="() => showNewPassword = !showNewPassword"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                        <i class="fa-solid @(showNewPassword ? "fa-eye-slash" : "fa-eye")"></i>
                    </button>
                </div>
                <!-- Password Strength Indicator -->
                @if (!string.IsNullOrEmpty(passwordModel.NewPassword))
                {
                    <div class="mt-2">
                        <div class="flex gap-1 mb-1">
                            @for (int i = 0; i < 4; i++)
                            {
                                <div class="h-1 flex-1 rounded-full @(i < GetPasswordStrength() ? GetStrengthColor() : "bg-slate-200")"></div>
                            }
                        </div>
                        <p class="text-xs @GetStrengthTextColor()">@GetStrengthText()</p>
                    </div>
                }
            </div>

            <!-- Confirm New Password -->
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Xác nhận mật khẩu mới <span class="text-fuchsia-600">*</span>
                </label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                        <i class="fa-solid fa-shield-halved"></i>
                    </span>
                    <InputText type="@(showConfirmPassword ? "text" : "password")" 
                               @bind-Value="passwordModel.ConfirmPassword" 
                               class="w-full pl-11 pr-12 py-3 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-fuchsia-500 focus:border-transparent transition"
                               placeholder="Nhập lại mật khẩu mới" />
                    <button type="button" 
                            @onclick="() => showConfirmPassword = !showConfirmPassword"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                        <i class="fa-solid @(showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                    </button>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit" 
                    disabled="@isChanging"
                    class="w-full py-3 bg-fuchsia-600 hover:bg-fuchsia-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
                @if (isChanging)
                {
                    <i class="fa-solid fa-spinner fa-spin mr-2"></i><span>Đang đổi mật khẩu...</span>
                }
                else
                {
                    <i class="fa-solid fa-check mr-2"></i><span>Đổi mật khẩu</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-6">
            <button @onclick='() => Navigation.NavigateTo("/settings")' 
                    class="text-slate-600 hover:text-slate-800 text-sm font-medium">
                <i class="fa-solid fa-arrow-left mr-2"></i>Quay lại Settings
            </button>
        </div>
    </div>
</div>

@code {
    private ChangePasswordModel passwordModel = new();
    private string successMessage = "";
    private string errorMessage = "";
    private bool isChanging = false;
    private bool showCurrentPassword = false;
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;

    private async Task HandleChangePassword()
    {
        isChanging = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            // Validate passwords match
            if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
            {
                errorMessage = "Mật khẩu mới và xác nhận không khớp!";
                return;
            }

            // Validate password length
            if (passwordModel.NewPassword.Length < 8)
            {
                errorMessage = "Mật khẩu mới phải có ít nhất 8 ký tự!";
                return;
            }

            // Get current user
            var currentUser = await AuthService.GetCurrentUserAsync();
            if (currentUser == null)
            {
                Navigation.NavigateTo("/login", true);
                return;
            }

            // TODO: Implement ChangePassword in AuthService
            Logger.LogInformation("Changing password for user: {Username}", currentUser.Username);
            
            await Task.Delay(500); // Simulate API call
            
            successMessage = "Đổi mật khẩu thành công! Đang chuyển hướng...";
            StateHasChanged();
            
            // Redirect to settings after 2 seconds
            await Task.Delay(2000);
            Navigation.NavigateTo("/settings");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing password");
            errorMessage = $"Đã xảy ra lỗi: {ex.Message}";
        }
        finally
        {
            isChanging = false;
            StateHasChanged();
        }
    }

    private int GetPasswordStrength()
    {
        if (string.IsNullOrEmpty(passwordModel.NewPassword)) return 0;
        
        int strength = 0;
        if (passwordModel.NewPassword.Length >= 8) strength++;
        if (passwordModel.NewPassword.Length >= 12) strength++;
        if (System.Text.RegularExpressions.Regex.IsMatch(passwordModel.NewPassword, @"[A-Z]") && 
            System.Text.RegularExpressions.Regex.IsMatch(passwordModel.NewPassword, @"[a-z]")) strength++;
        if (System.Text.RegularExpressions.Regex.IsMatch(passwordModel.NewPassword, @"[0-9]") && 
            System.Text.RegularExpressions.Regex.IsMatch(passwordModel.NewPassword, @"[^a-zA-Z0-9]")) strength++;
        
        return strength;
    }

    private string GetStrengthColor()
    {
        return GetPasswordStrength() switch
        {
            1 => "bg-red-500",
            2 => "bg-orange-500",
            3 => "bg-yellow-500",
            4 => "bg-green-500",
            _ => "bg-slate-200"
        };
    }

    private string GetStrengthTextColor()
    {
        return GetPasswordStrength() switch
        {
            1 => "text-red-600",
            2 => "text-orange-600",
            3 => "text-yellow-600",
            4 => "text-green-600",
            _ => "text-slate-400"
        };
    }

    private string GetStrengthText()
    {
        return GetPasswordStrength() switch
        {
            1 => "Mật khẩu yếu",
            2 => "Mật khẩu trung bình",
            3 => "Mật khẩu khá",
            4 => "Mật khẩu mạnh",
            _ => ""
        };
    }

    public class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
