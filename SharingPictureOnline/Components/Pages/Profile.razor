@page "/profile"
@page "/profile/{Username}"
@rendermode InteractiveServer
@implements IDisposable
@using SharingPictureOnline.Services
@using Microsoft.Extensions.Logging
@inject IAuthService AuthService
@inject IPhotoService PhotoService
@inject IAlbumService AlbumService
@inject IFollowService FollowService
@inject NavigationManager Navigation
@inject ILogger<Profile> Logger
@inject NotificationStateService NotifState

<PageTitle>@(profileUser?.Username ?? "Profile") | FakePinterest</PageTitle>

@if (profileUser == null)
{
    <div class="min-h-screen flex items-center justify-center">
        <div class="text-center">
            <i class="fa-solid fa-spinner fa-spin text-4xl text-fuchsia-600 mb-4"></i>
            <p class="text-slate-500">Đang tải profile...</p>
        </div>
    </div>
}
else
{
    <div class="bg-slate-50 min-h-screen">
        <div class="bg-white shadow-sm">
            <div class="max-w-6xl mx-auto px-4 py-8">
                <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
                    <div class="flex-shrink-0">
                        @if (!string.IsNullOrEmpty(profileUser.UserProfile?.AvatarUrl))
                        {
                            <img src="@profileUser.UserProfile.AvatarUrl" alt="@profileUser.Username" class="w-32 h-32 rounded-full object-cover shadow-xl border-4 border-white">
                        }
                        else
                        {
                            <img src="/images/default-avatar.svg" alt="Default Avatar" class="w-32 h-32 rounded-full object-cover shadow-xl border-4 border-white bg-slate-200">
                        }
                    </div>

                    <div class="flex-1 text-center md:text-left">
                        <div class="flex flex-col md:flex-row md:items-center gap-4 mb-4">
                            <div>
                                <h1 class="text-3xl font-bold text-slate-800">
                                    @(profileUser.UserProfile?.DisplayName ?? profileUser.Username)
                                </h1>
                                @if (!string.IsNullOrEmpty(profileUser.UserProfile?.DisplayName))
                                {
                                    <p class="text-slate-500 text-sm">@("@" + profileUser.Username)</p>
                                }
                            </div>

                            @if (isOwnProfile)
                            {
                                <a href="/settings" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium text-sm transition inline-flex items-center gap-2">
                                    <i class="fa-solid fa-pen"></i>
                                    <span>Chỉnh sửa profile</span>
                                </a>
                            }
                            else
                            {
                                @if (isFollowing)
                                {
                                    <button @onclick="ToggleFollow" class="px-6 py-2 bg-slate-200 hover:bg-slate-300 text-slate-800 rounded-lg font-semibold text-sm transition shadow-md flex items-center">
                                        <i class="fa-solid fa-user-check mr-2"></i>Đang theo dõi
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="ToggleFollow" class="px-6 py-2 bg-fuchsia-600 hover:bg-fuchsia-700 text-white rounded-lg font-semibold text-sm transition shadow-md flex items-center">
                                        <i class="fa-solid fa-user-plus mr-2"></i>Theo dõi
                                    </button>
                                }
                            }
                        </div>

                        <div class="flex items-center justify-center md:justify-start gap-6 mb-4">
                            <div class="text-center">
                                <span class="block text-2xl font-bold text-slate-800">@userPhotos.Count</span>
                                <span class="text-sm text-slate-500">photos</span>
                            </div>
                            <div class="text-center">
                                <span class="block text-2xl font-bold text-slate-800">@userAlbums.Count</span>
                                <span class="text-sm text-slate-500">albums</span>
                            </div>
                            <div class="text-center">
                                <span class="block text-2xl font-bold text-slate-800">@followersCount</span>
                                <span class="text-sm text-slate-500">followers</span>
                            </div>
                            <div class="text-center">
                                <span class="block text-2xl font-bold text-slate-800">@followingCount</span>
                                <span class="text-sm text-slate-500">following</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(profileUser.UserProfile?.Bio))
                        {
                            <p class="text-slate-600 leading-relaxed max-w-2xl">
                                @profileUser.UserProfile.Bio
                            </p>
                        }
                        else if (isOwnProfile)
                        {
                            <p class="text-slate-400 italic">
                                Thêm bio để chia sẻ về bản thân bạn...
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(profileUser.UserProfile?.Website))
                        {
                            <div class="mt-3">
                                <a href="@profileUser.UserProfile.Website" target="_blank" class="text-fuchsia-600 hover:text-fuchsia-700 font-medium inline-flex items-center gap-2">
                                    <i class="fa-solid fa-link"></i>
                                    <span>@profileUser.UserProfile.Website</span>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border-b border-slate-200 sticky top-16 z-30">
            <div class="max-w-6xl mx-auto px-4">
                <div class="flex gap-8">
                    <button @onclick='() => activeTab = "photos"'
                            class="py-4 font-semibold text-sm transition border-b-2 @(activeTab == "photos" ? "text-fuchsia-600 border-fuchsia-600" : "text-slate-500 border-transparent hover:text-slate-700")">
                        <i class="fa-solid fa-images mr-2"></i>@(isOwnProfile ? "My Photos" : "Photos")
                    </button>
                    <button @onclick='() => activeTab = "albums"'
                            class="py-4 font-semibold text-sm transition border-b-2 @(activeTab == "albums" ? "text-fuchsia-600 border-fuchsia-600" : "text-slate-500 border-transparent hover:text-slate-700")">
                        <i class="fa-solid fa-folder mr-2"></i>@(isOwnProfile ? "My Albums" : "Albums")
                    </button>
                </div>
            </div>
        </div>

        <div class="max-w-6xl mx-auto px-4 py-8">
            @if (activeTab == "photos")
            {
                @if (userPhotos.Any())
                {
                    <div class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
                        @foreach (var photo in userPhotos)
                        {
                            <a href="/photo/@photo.PhotoId" class="block break-inside-avoid relative group rounded-xl overflow-hidden shadow-sm bg-slate-200 hover:shadow-xl transition cursor-pointer">
                                <img src="@photo.StorageKey" alt="@photo.Title" class="w-full object-cover">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition p-4 flex flex-col justify-end">
                                    <p class="text-white font-semibold">@photo.Title</p>
                                    <div class="flex items-center gap-3 mt-2 text-white text-sm">
                                        <span><i class="fa-solid fa-heart mr-1"></i>@photo.LikeCount</span>
                                        <span><i class="fa-solid fa-comment mr-1"></i>@photo.CommentCount</span>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-20">
                        <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fa-solid fa-camera text-4xl text-slate-300"></i>
                        </div>
                        <h3 class="text-xl font-semibold text-slate-800 mb-2">Chưa có ảnh nào</h3>
                        @if (isOwnProfile)
                        {
                            <p class="text-slate-500 mb-4">Hãy bắt đầu chia sẻ ảnh của bạn!</p>
                            <a href="/upload" class="inline-block px-6 py-3 bg-fuchsia-600 hover:bg-fuchsia-700 text-white rounded-lg font-semibold shadow-md transition">
                                <i class="fa-solid fa-upload mr-2"></i>Upload ảnh đầu tiên
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                @if (userAlbums.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        @foreach (var album in userAlbums)
                        {
                            <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition cursor-pointer overflow-hidden group">
                                <div class="aspect-video bg-gradient-to-br from-fuchsia-100 to-pink-100 flex items-center justify-center">
                                    <i class="fa-solid fa-folder-open text-6xl text-fuchsia-300 group-hover:scale-110 transition"></i>
                                </div>
                                <div class="p-4">
                                    <h3 class="font-semibold text-slate-800 mb-1">@album.Title</h3>
                                    <p class="text-sm text-slate-500">0 photos</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-20">
                        <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fa-solid fa-folder text-4xl text-slate-300"></i>
                        </div>
                        <h3 class="text-xl font-semibold text-slate-800 mb-2">Chưa có album nào</h3>
                        @if (isOwnProfile)
                        {
                            <p class="text-slate-500 mb-4">Tạo album để tổ chức ảnh của bạn!</p>
                            <button disabled class="px-6 py-3 bg-slate-400 text-white rounded-lg font-semibold shadow-md cursor-not-allowed">
                                <i class="fa-solid fa-plus mr-2"></i>Tạo album mới (Coming soon)
                            </button>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string? Username { get; set; }

    private Models.User? profileUser;
    private Models.User? currentUser;
    private bool isOwnProfile = false;
    private string activeTab = "photos";
    private List<Models.Photo> userPhotos = new();
    private List<Models.Album> userAlbums = new();

    private bool isFollowing = false;
    private int followersCount = 0;
    private int followingCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProfile();
        }
    }

    private async Task LoadProfile()
    {
        try
        {
            currentUser = await AuthService.GetCurrentUserAsync();

            if (string.IsNullOrEmpty(Username))
            {
                if (currentUser == null)
                {
                    Navigation.NavigateTo("/login", true);
                    return;
                }
                profileUser = currentUser;
                isOwnProfile = true;
            }
            else
            {
                profileUser = await AuthService.GetUserByUsernameAsync(Username);
                if (profileUser == null)
                {
                    Navigation.NavigateTo("/");
                    return;
                }

                isOwnProfile = currentUser != null && currentUser.Username == Username;

                if (!isOwnProfile && currentUser != null)
                {
                    isFollowing = await FollowService.IsFollowingAsync(currentUser.UserId, profileUser.UserId);
                }
            }

            if (profileUser != null)
            {
                userPhotos = (await PhotoService.GetPhotosByUserIdAsync(profileUser.UserId, includeHidden: isOwnProfile)).ToList();
                userAlbums = (await AlbumService.GetAllAlbumsAsync())
                    .Where(a => a.UserId == profileUser.UserId).ToList();

                // Load dữ liệu
                followersCount = await FollowService.GetFollowersCountAsync(profileUser.UserId);
                followingCount = await FollowService.GetFollowingCountAsync(profileUser.UserId);

                // 👉 ĐĂNG KÝ NHẬN TÍN HIỆU REALTIME
                NotifState.OnFollowStatsChanged -= HandleStatsChanged;
                NotifState.OnFollowStatsChanged += HandleStatsChanged;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading profile");
        }
        finally
        {
            StateHasChanged();
        }
    }

    // 👉 HÀM NÀY SẼ CHẠY KHI CÓ NGƯỜI FOLLOW/UNFOLLOW
    private async void HandleStatsChanged(Guid targetUserId)
    {
        // Kiểm tra xem trang Profile đang mở có đúng là trang của người bị Follow/Unfollow không
        if (profileUser != null && profileUser.UserId == targetUserId)
        {
            await InvokeAsync(async () =>
            {
                // Lấy lại số Follower chuẩn từ Database và vẽ lại giao diện
                followersCount = await FollowService.GetFollowersCountAsync(profileUser.UserId);
                StateHasChanged();
            });
        }
    }

    private async Task ToggleFollow()
    {
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (profileUser == null) return;

        try
        {
            isFollowing = await FollowService.ToggleFollowAsync(currentUser.UserId, profileUser.UserId);

            // Tạm thời cộng trừ trên màn hình của người đang bấm để tạo cảm giác mượt mà
            if (isFollowing)
            {
                followersCount++;
            }
            else
            {
                followersCount--;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi khi xử lý thao tác follow/unfollow");
        }
    }

    private void GoToPhotoDetail(Guid photoId)
    {
        Navigation.NavigateTo($"/photo/{photoId}");
    }

    // 👉 GỠ ĂNG-TEN KHI ĐÓNG TRANG
    public void Dispose()
    {
        if (NotifState != null)
        {
            NotifState.OnFollowStatsChanged -= HandleStatsChanged;
        }
    }
}