@inherits LayoutComponentBase
@using SharingPictureOnline.Services
@using SharingPictureOnline.Repositories
@inject IAuthService AuthService
@inject INotificationRepository NotifRepo
@inject NotificationStateService NotifState
@inject NavigationManager Navigation
@implements IDisposable
@inject INotificationService NotifService

<header class="bg-white shadow-sm sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-fuchsia-600 flex items-center gap-2">
            <i class="fa-solid fa-camera-retro"></i> FakePinterest
        </a>
        <div class="flex gap-2 items-center">
            @if (isAuthenticated && currentUser != null)
            {
                <div class="flex items-center gap-4">
                    @if (currentUser.Role == "ADMIN")
                    {
                        <a href="/admin" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium text-sm shadow-sm transition inline-flex items-center gap-2">
                            <i class="fa-solid fa-shield-halved"></i>
                            <span>Admin</span>
                        </a>
                    }
                    <a href="/upload" class="px-4 py-2 bg-fuchsia-600 hover:bg-fuchsia-700 text-white rounded-lg font-medium text-sm shadow-sm transition inline-flex items-center gap-2">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <span>Upload</span>
                    </a>

                    <div class="relative">
                        <button @onclick="ToggleNotificationMenu" class="relative w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 flex items-center justify-center transition">
                            <i class="fa-solid fa-bell text-slate-600"></i>
                            @if (unreadCount > 0)
                            {
                                <span class="absolute top-0 right-0 inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-red-500 rounded-full border-2 border-white -mt-1 -mr-1">
                                    @(unreadCount > 99 ? "99+" : unreadCount)
                                </span>
                            }
                        </button>

                        @if (showNotificationMenu)
                        {
                            <div class="absolute right-0 mt-2 w-80 bg-white rounded-lg shadow-xl border border-slate-200 py-2 z-50 max-h-96 overflow-y-auto">
                                <div class="px-4 py-2 border-b border-slate-100 font-semibold text-slate-800">Thông báo</div>

                                @if (notifications.Any())
                                {
                                    @foreach (var notif in notifications)
                                    {
                                        <div class="px-4 py-3 hover:bg-slate-50 transition border-b border-slate-50 flex items-start gap-3">
                                            <i class="fa-solid fa-user-plus text-fuchsia-600 mt-1"></i>
                                            <div>
                                                <p class="text-sm text-slate-700">
                                                    <span class="font-bold">@GetUsernameFromId(notif.RefId)</span>
                                                    đã theo dõi bạn!
                                                </p>
                                                <span class="text-xs text-slate-400">@notif.CreatedAt.ToString("HH:mm dd/MM")</span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="px-4 py-6 text-center text-slate-400 text-sm italic">Không có thông báo mới</div>
                                }
                            </div>
                        }
                    </div>

                    <div class="relative" @onclick="ToggleUserMenu">
                        @if (!string.IsNullOrEmpty(currentUser.UserProfile?.AvatarUrl))
                        {
                            <img src="@currentUser.UserProfile.AvatarUrl"
                                 alt="@currentUser.Username"
                                 class="w-10 h-10 rounded-full object-cover cursor-pointer ring-2 ring-fuchsia-200 hover:ring-fuchsia-400 transition" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-full bg-fuchsia-100 text-fuchsia-600 flex items-center justify-center font-bold text-sm cursor-pointer hover:bg-fuchsia-200 transition">
                                @(GetUserInitial(currentUser.Username))
                            </div>
                        }
                        @if (showUserMenu)
                        {
                            <div class="absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-xl border border-slate-200 py-2 z-50">
                                <div class="px-4 py-3 border-b border-slate-200">
                                    <p class="text-sm font-semibold text-slate-800">@currentUser.Username</p>
                                    <p class="text-xs text-slate-500">@currentUser.Email</p>
                                    @if (currentUser.Role == "ADMIN")
                                    {
                                        <span class="inline-block mt-1 px-2 py-0.5 bg-red-100 text-red-700 rounded text-xs font-semibold">
                                            <i class="fa-solid fa-crown mr-1"></i>ADMIN
                                        </span>
                                    }
                                    else if (currentUser.Role == "MODERATOR")
                                    {
                                        <span class="inline-block mt-1 px-2 py-0.5 bg-blue-100 text-blue-700 rounded text-xs font-semibold">
                                            <i class="fa-solid fa-shield-halved mr-1"></i>MODERATOR
                                        </span>
                                    }
                                </div>
                                @if (currentUser.Role == "ADMIN")
                                {
                                    <div class="border-b border-slate-200 pb-2 mb-2">
                                        <a href="/admin" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 font-semibold">
                                            <i class="fa-solid fa-shield-halved mr-2"></i>Admin Dashboard
                                        </a>
                                        <a href="/admin/accounts" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 pl-10">
                                            <i class="fa-solid fa-users mr-2 text-xs"></i>Tài khoản
                                        </a>
                                        <a href="/admin/tags" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 pl-10">
                                            <i class="fa-solid fa-tags mr-2 text-xs"></i>Tags
                                        </a>
                                        <a href="/admin/settings" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 pl-10">
                                            <i class="fa-solid fa-cog mr-2 text-xs"></i>Cài đặt
                                        </a>
                                    </div>
                                }
                                <a href="/profile" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                                    <i class="fa-solid fa-user mr-2"></i>Trang cá nhân
                                </a>
                                <a href="/settings" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
                                    <i class="fa-solid fa-gear mr-2"></i>Cài đặt
                                </a>
                                <button @onclick="HandleLogout" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50">
                                    <i class="fa-solid fa-right-from-bracket mr-2"></i>Đăng xuất
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <a href="/login" class="px-4 py-2 text-slate-500 hover:text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium text-sm transition">
                    Đăng nhập
                </a>
                <a href="/register" class="px-4 py-2 bg-fuchsia-600 text-white rounded-lg hover:bg-fuchsia-700 font-medium text-sm shadow-sm transition">
                    Đăng ký
                </a>
            }
        </div>
    </div>
</header>

@Body

@code {
    private bool isAuthenticated = false;
    private Models.User? currentUser = null;
    private bool showUserMenu = false;
    private bool isInitialized = false;
    private bool showNotificationMenu = false;

    private List<SharingPictureOnline.Models.Notification> notifications = new();
    private Dictionary<Guid, string> followerNames = new(); // Bộ nhớ tạm lưu tên
    private int unreadCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !isInitialized)
        {
            isInitialized = true;
            await UpdateAuthState();
        }
    }

    private async Task UpdateAuthState()
    {
        try
        {
            currentUser = await AuthService.GetCurrentUserAsync();
            isAuthenticated = currentUser != null;

            if (isAuthenticated && currentUser != null)
            {
                unreadCount = await NotifRepo.CountUnreadAsync(currentUser.UserId);
                notifications = await NotifRepo.GetUnreadByUserIdAsync(currentUser.UserId);

                // Tải tên người theo dõi ngay khi load danh sách thông báo
                await LoadFollowerNamesAsync(notifications);

                NotifState.OnNotificationReceived += HandleNewNotification;
            }

            StateHasChanged();
        }
        catch (Exception)
        {
            // Bỏ qua lỗi
        }
    }

    private async Task ToggleNotificationMenu()
    {
        showNotificationMenu = !showNotificationMenu;

        if (showNotificationMenu && unreadCount > 0)
        {
            await NotifService.MarkAllAsReadAsync(currentUser.UserId);
            unreadCount = 0;
            StateHasChanged();
        }
    }

    private async void HandleNewNotification(Guid targetUserId)
    {
        await InvokeAsync(async () =>
        {
            if (currentUser != null && targetUserId == currentUser.UserId)
            {
                unreadCount++;
                notifications = await NotifRepo.GetUnreadByUserIdAsync(currentUser.UserId);

                // Tải thêm tên người theo dõi cho thông báo mới
                await LoadFollowerNamesAsync(notifications);

                StateHasChanged();
            }
        });
    }

    // HÀM MỚI: Tải tên người dùng từ DB và lưu vào Dictionary
    private async Task LoadFollowerNamesAsync(List<SharingPictureOnline.Models.Notification> notifs)
    {
        foreach (var n in notifs)
        {
            if (n.RefId.HasValue && !followerNames.ContainsKey(n.RefId.Value))
            {
                var user = await AuthService.GetUserByIdAsync(n.RefId.Value);
                followerNames[n.RefId.Value] = user?.Username ?? "Ai đó";
            }
        }
    }

    // HÀM MỚI: Lấy tên siêu nhanh từ Dictionary để hiển thị ra UI
    private string GetUsernameFromId(Guid? refId)
    {
        if (!refId.HasValue) return "Ai đó";
        return followerNames.TryGetValue(refId.Value, out var name) ? name : "Ai đó";
    }

    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        showUserMenu = false;
        Navigation.NavigateTo("/", true);
    }

    public void Dispose()
    {
        if (NotifState != null)
        {
            NotifState.OnNotificationReceived -= HandleNewNotification;
        }
    }

    private string GetUserInitial(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        return username.Substring(0, 1).ToUpper();
    }
}